<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Enter PIN - PlaceOS CampusOS</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      background: linear-gradient(135deg, #1a3a5c 0%, #2c4a6c 100%);
    }
    .pin-container {
      background: white;
      border-radius: 16px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
      padding: 48px;
      max-width: 400px;
      width: 90%;
      text-align: center;
    }
    .pin-logo {
      font-size: 2em;
      font-weight: 700;
      color: #1a3a5c;
      letter-spacing: -0.5px;
      margin-bottom: 8px;
    }
    .pin-logo span {
      color: #2c4a6c;
      font-weight: 300;
    }
    .pin-icon {
      font-size: 3em;
      margin: 16px 0;
    }
    h1 {
      font-size: 1.8em;
      color: #333;
      margin-bottom: 8px;
      font-weight: 600;
    }
    p {
      color: #666;
      margin-bottom: 32px;
      line-height: 1.6;
    }
    #pinInput {
      width: 100%;
      padding: 16px;
      font-size: 2em;
      text-align: center;
      border: 2px solid #e0e0e0;
      border-radius: 12px;
      letter-spacing: 8px;
      margin-bottom: 16px;
      font-weight: 600;
      transition: border-color 0.3s;
    }
    #pinInput:focus {
      outline: none;
      border-color: #1a3a5c;
    }
    #pinInput.error {
      border-color: #e74c3c;
      animation: shake 0.5s;
    }
    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-10px); }
      75% { transform: translateX(10px); }
    }
    .error-msg {
      color: #e74c3c;
      font-size: 0.9em;
      margin-bottom: 16px;
      display: none;
    }
    .error-msg.show {
      display: block;
    }
    button {
      width: 100%;
      padding: 16px;
      background: linear-gradient(135deg, #1a3a5c 0%, #2c4a6c 100%);
      color: white;
      border: none;
      border-radius: 12px;
      font-size: 1.1em;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
    }
    button:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(26,58,92,0.4);
    }
    button:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
    }
    .hint {
      margin-top: 24px;
      font-size: 0.85em;
      color: #999;
    }
  </style>
</head>
<body>
  <div class="pin-container">
    <div class="pin-logo">Place<span>OS</span></div>
    <div class="pin-icon"><svg viewBox="0 0 24 24" style="width:48px; height:48px; stroke:#4a90d9; fill:none; stroke-width:1.5;"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div>
    <h1>Protected Proposal</h1>
    <p>This proposal is protected with a PIN code. Please enter the 4-digit PIN to continue.</p>

    <form id="pinForm">
      <input
        type="password"
        id="pinInput"
        maxlength="4"
        pattern="[0-9]{4}"
        placeholder="••••"
        autocomplete="off"
        autofocus
        inputmode="numeric"
      >
      <div class="error-msg" id="errorMsg">
        Incorrect PIN. Please try again.
      </div>
      <button type="submit" id="submitBtn">
        <span id="btnText">Unlock Proposal</span>
        <span id="btnLoading" style="display:none;">Verifying...</span>
      </button>
    </form>

    <div class="hint">
      Forgot your PIN? Contact the person who shared this link with you.
    </div>
  </div>

  <script>
    (function() {
      const form = document.getElementById('pinForm');
      const input = document.getElementById('pinInput');
      const errorMsg = document.getElementById('errorMsg');
      const submitBtn = document.getElementById('submitBtn');
      const btnText = document.getElementById('btnText');
      const btnLoading = document.getElementById('btnLoading');

      input.addEventListener('input', () => {
        input.classList.remove('error');
        errorMsg.classList.remove('show');
        input.value = input.value.replace(/[^0-9]/g, '');
        if (input.value.length === 4) {
          setTimeout(() => form.dispatchEvent(new Event('submit')), 300);
        }
      });

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const pin = input.value;

        if (pin.length !== 4) {
          input.classList.add('error');
          errorMsg.textContent = 'PIN must be exactly 4 digits.';
          errorMsg.classList.add('show');
          return;
        }

        submitBtn.disabled = true;
        btnText.style.display = 'none';
        btnLoading.style.display = 'inline';

        try {
          const res = await fetch('/<%= slug %>/verify-pin', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ pin }),
          });

          if (res.ok) {
            const currentPath = window.location.pathname;
            const targetPath = currentPath.includes('/invoice')
              ? '/<%= slug %>/invoice?pin=' + encodeURIComponent(pin)
              : '/<%= slug %>?pin=' + encodeURIComponent(pin);
            window.location.href = targetPath;
          } else {
            input.classList.add('error');
            errorMsg.classList.add('show');
            input.value = '';
            input.focus();
            submitBtn.disabled = false;
            btnText.style.display = 'inline';
            btnLoading.style.display = 'none';
          }
        } catch (err) {
          alert('Network error. Please try again.');
          submitBtn.disabled = false;
          btnText.style.display = 'inline';
          btnLoading.style.display = 'none';
        }
      });
    })();
  </script>
</body>
</html>
